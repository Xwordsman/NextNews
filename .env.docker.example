NEXTNEWS_IMAGE=ghcr.io/xwordsman/nextnews:latest
WEB_PORT=3000
APP_URL=https://news.example.com

POSTGRES_DB=nextnews
POSTGRES_USER=nextnews
POSTGRES_PASSWORD=please-change-this-postgres-password

AUTH_SECRET=please-change-this-long-random-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=please-change-this-admin-password

WORKER_POLL_INTERVAL_SECONDS=30
CRAWL_BATCH_SIZE=5
CRAWL_CONCURRENCY=3
CRAWL_RUNNING_TIMEOUT_SECONDS=900
CRAWL_MIN_SNAPSHOT_INTERVAL_SECONDS=600
CRAWL_SIGNIFICANT_TOP_CHANGE_COUNT=3
CRAWL_SIGNIFICANT_TOP_LIMIT=10
